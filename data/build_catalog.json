			"default_item_id": "structure_room_select",
			"items": [
				{
					"id": "structure_room_select",
					"label": "Select Room",
					"description": "Select a room and move or resize it directly.",
					"payload": {
						"action": "room_select"
					}
				},
				{
					"id": "structure_room_delete",
					"label": "Delete Selected Room",
					"description": "Delete walls around the currently selected room.",
					"payload": {
						"action": "room_delete_selected"
					}
				},
				{
					"id": "structure_wall_select",
					"label": "Select / Move Wall",
					"description": "Select an existing wall segment and drag to move it.",
					"payload": {
						"action": "wall_select"
					}
				},
				{
					"id": "structure_wall_draw",
					"label": "Draw Wall",
					"description": "Draw wall segments. Shift still draws rectangle and Ctrl still deletes.",
					"payload": {
						"action": "wall_draw"
					}
				},
				{
					"id": "structure_wall_rectangle",
					"label": "Rectangle",
