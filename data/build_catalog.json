					"payload": {
						"action": "wall_rectangle"
					}
				},
				{
					"id": "structure_wall_delete",
					"label": "Delete Wall",
					"description": "Delete walls by dragging over them.",
					"payload": {
						"action": "wall_delete"
					}
				}
			]
		},
